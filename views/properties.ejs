<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MeetMyHomes</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .properties-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2rem;
      margin: 2rem 0;
    }
    .property-card {
      border: 1px solid #eaeaea;
      border-radius: 8px;
      overflow: hidden;
      transition: transform 0.3s;
    }
    .property-card:hover {
      transform: translateY(-5px);
    }
    .property-image {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }
    .property-info {
      padding: 1.5rem;
    }
    .price {
      font-size: 1.5rem;
      font-weight: bold;
      color: #2c3e50;
    }
    .features {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 1rem 0;
    }
    .feature {
      background: #f8f9fa;
      padding: 0.3rem 0.8rem;
      border-radius: 20px;
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <%- include('partials/header') %>

  <main class="container">
    <h1><%= title %></h1>
    
    <div class="properties-grid">
      <% properties.forEach(property => { %>
        <a href="/properties/<%= property.id %>" class="property-card">
          <img src="<%= property.images[0] %>" alt="<%= property.title %>" class="property-image">
          <div class="property-info">
            <div class="price"><%= property.price %></div>
            <h2><%= property.title %></h2>
            <p><%= property.location %></p>
            <div class="features">
              <span class="feature"><%= property.area %></span>
              <span class="feature"><%= property.bedrooms %> beds</span>
              <span class="feature"><%= property.bathrooms %> baths</span>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>