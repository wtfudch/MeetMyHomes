<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home - MeetMyHomes</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('partials/header') %>

  <!-- Hero Section -->
  <section class="hero">
    <h1>Find Your Dream Home</h1>
    <p></p>
  </section>

  <!-- Property Grid Section -->
  <section class="property-grid">
    <h2>Featured Properties</h2>
    <div class="grid-container">
      <div class="property-card">
        <img src="/images/casaNeves/casaNeves17.jpeg" alt="Property 1">
        <button onclick="window.location.href='/casaNeves'">View Details</button>
      </div>
      <div class="property-card">
        <img src="/images/arcoApartment/arcoApartment4.jpeg" alt="Property 2">
        <button onclick="window.location.href='/arcoApartment'">View Details</button>
      </div>
      <div class="property-card">
        <img src="/images/casa.jpg" alt="Property 3">
        <button onclick="window.location.href='/property/3'">View Details</button>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script src="/js/script.js"></script>
</body>
</html>