<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Listings - MeetMyHomes</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .listings-container {
      display: flex;
      margin-bottom: 40px;
      gap: 20px;
      min-height: 300px; /* Minimum height for both sections */
    }
    
    .property-images {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    
    .image-container {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: #f5f5f5;
    }
    
    .image-container img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .image-controls {
      display: flex;
      justify-content: space-between;
      margin-top: 10px;
    }
    
    .property-details {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    
    .property-card {
      flex: 1;
      padding: 20px;
      border: 1px solid #ddd;
      border-radius: 8px;
      display: flex;
      flex-direction: column;
    }
    
    #view-details-button-casa-neves,
    #view-details-button-arco-apartment {
      margin-top: auto;
      align-self: flex-start;
      padding: 10px 20px;
      background: #4285F4;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <%- include('partials/header') %>

  <!-- Casa Neves Section -->
  <h1>Casa Neves</h1>
  <div class="listings-container">
    <div class="property-images">
      <div class="image-container">
        <img src="" alt="Casa Neves" id="casa-neves-image">
      </div>
      <div class="image-controls">
        <button id="casa-neves-prev">&larr; Previous</button>
        <span id="casa-neves-counter">1/3</span>
        <button id="casa-neves-next">Next &rarr;</button>
      </div>
    </div>

    <div class="property-details">
      <div class="property-card">
        <h2>Casa Neves</h2>
        <p class="description">A charming house in a quiet neighborhood.</p>
        <p class="location">Location: Funchal, Portugal</p>
        <p class="type">Type: House</p>
        <button id="view-details-button-casa-neves">View Details</button>
      </div>
    </div>
  </div>

  <!-- Arco Apartment Section -->
  <h1>Arco Apartment</h1>
  <div class="listings-container">
    <div class="property-images">
      <div class="image-container">
        <img src="" alt="Arco Apartment" id="arco-apartment-image">
      </div>
      <div class="image-controls">
        <button id="arco-apartment-prev">&larr; Previous</button>
        <span id="arco-apartment-counter">1/3</span>
        <button id="arco-apartment-next">Next &rarr;</button>
      </div>
    </div>

    <div class="property-details">
      <div class="property-card">
        <h2>Arco Apartment</h2>
        <p class="description">A modern apartment in the heart of the city.</p>
        <p class="location">Location: Funchal, Portugal</p>
        <p class="type">Type: Apartment</p>
        <button id="view-details-button-arco-apartment">View Details</button>
      </div>
    </div>
  </div>
  
  <%- include('partials/footer') %>

  <script src="/js/script.js"></script>
</body>
</html>